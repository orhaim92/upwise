# Postgres — Neon (auto-set by Vercel Neon integration in production).
# For local dev: run `npx vercel env pull .env.local` after `npx vercel link`,
# or copy from Vercel project → Storage → Neon → .env.local tab.
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Auth.js v5 — generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Bank credential encryption key (32 bytes base64). Generate the same way as AUTH_SECRET.
# Add to Vercel env vars (Production, Preview, Development).
# WARNING: rotating this key makes all existing encrypted_credentials unreadable.
BANK_CREDS_KEY=

# === AI advisor (Phase 6) ===
# Get key from https://aistudio.google.com/apikey (free tier covers personal use)
GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
FEATURE_ADVISOR=true

# === Web Push / PWA (Phase 7) ===
# Generate with: npx web-push generate-vapid-keys
# Public key MUST also be exposed via NEXT_PUBLIC_* so the client can subscribe.
# WARNING: rotating these keys invalidates every existing push subscription.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
